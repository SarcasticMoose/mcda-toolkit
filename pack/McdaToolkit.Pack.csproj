  <ItemGroup>
    <ProjectReference Include="..\src\McdaToolkit.Core\McdaToolkit.Core.csproj" />
    <ProjectReference Include="..\src\McdaToolkit.Normalization\McdaToolkit.Normalization.csproj" />
    <ProjectReference Include="..\src\McdaToolkit.Validation\McdaToolkit.Validation.csproj" />
    <ProjectReference Include="..\src\McdaToolkit.Pipeline\McdaToolkit.Pipeline.csproj" />
  </ItemGroup>

</Project>
