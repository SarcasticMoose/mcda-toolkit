<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>McdaToolkit</PackageId>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeReferencedProjects>false</IncludeReferencedProjects>
    <Description>A flexible .NET library for Multi-Criteria Decision Analysis (MCDA). Provides a pipeline-based architecture for structuring, evaluating, and solving decision-making problems with multiple conflicting criteria using pluggable MCDA methods and extensions.</Description>
